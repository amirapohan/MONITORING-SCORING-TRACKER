model User {
  id                 String                    @id @default(uuid()) @db.Uuid
  name               String
  username           String?                   @unique
  email              String                    @unique
  password           String?
  role               UserRole                  @default(talent)
  isActive           Boolean                   @default(true) @map("is_active")
  refreshTokens      RefreshToken[]
  oauthAccounts      UserOAuthAccount[]
  profile            UserProfile?
  portfolios         Portfolio[]
  skills             Skill[]                   @default([])
  subSkills          SubSkill[]                @default([]) @map("sub_skills")
  projectCompletions TalentProjectCompletion[]
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @db.Text
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model UserOAuthAccount {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  provider   String
  providerId String   @map("provider_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([provider, providerId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("user_oauth_accounts")
}

model UserProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @map("users_id") @db.Uuid
  headline           String?
  bio                String?
  location           String?
  availabilityStatus String?  @map("availability_status")
  hourlyRate         Decimal? @map("hourly_rate") @db.Decimal(12, 2)
  experienceLevel    String?  @map("experience_level")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model Portfolio {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String
  type        String
  description String?
  url         String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("portfolios")
}

model AuditLog {
  id             String      @id @default(uuid()) @db.Uuid
  action         AuditAction
  userId         String?     @map("user_id") @db.Uuid
  ip             String?
  userAgent      String?     @map("user_agent")
  metadata       Json?
  outboxEventId  String?     @unique @map("outbox_event_id") @db.Uuid
  createdAt      DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model OutboxEvent {
  id          String      @id @default(uuid()) @db.Uuid
  eventType   AuditAction @map("event_type")
  userId      String?     @map("user_id") @db.Uuid
  ip          String?
  userAgent   String?     @map("user_agent")
  payload     Json
  createdAt   DateTime    @default(now()) @map("created_at")
  publishedAt DateTime?   @map("published_at")

  @@index([publishedAt])
  @@map("outbox_events")
}

model TalentProjectCompletion {
  id             String   @id @default(uuid()) @db.Uuid
  talentId       String   @map("talent_id") @db.Uuid
  projectId      String   @map("project_id")
  tokenId        String   @map("token_id")
  ipfsUri        String   @map("ipfs_uri")
  completionDate DateTime @map("completion_date")
  talent         User     @relation(fields: [talentId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([talentId, projectId])
  @@index([talentId])
  @@index([projectId])
  @@map("talent_project_completions")
}
