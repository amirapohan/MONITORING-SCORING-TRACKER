              },
              {
                "key": "x-internal-api-key",
                "value": "{{INTERNAL_API_KEY}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/internal/validate-token",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "internal",
                "validate-token"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{accessToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
