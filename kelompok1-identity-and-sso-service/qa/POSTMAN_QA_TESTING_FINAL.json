              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
      "name": "4. Internal API",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-internal-api-key",
                "value": "{{INTERNAL_API_KEY}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/internal/users",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "internal",
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.success && jsonData.data.users.length > 0) {",
                  "  pm.environment.set('target_user_id', jsonData.data.users[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-internal-api-key",
                "value": "{{INTERNAL_API_KEY}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/internal/users/{{target_user_id}}",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "internal",
                "users",
                "{{target_user_id}}"
              ]
            }
          }
        },
