# Monitoring & Scoring (Tracker) — svc-audit
# Copy to .env and fill in. Do NOT commit real secrets.

# ---- Database (Prisma / PostgreSQL) ----
DATABASE_URL=postgresql://kel4:kel4@localhost:5432/kel4?schema=public

# ---- Redis (assessment cache-aside) ----
REDIS_URL=redis://localhost:6379

# ---- HTTP ----
PORT=8080

RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=tracker.events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_ROUTING_PREFIX=tracker
RABBITMQ_PUBLISH_RETRIES=3
RABBITMQ_PUBLISH_RETRY_DELAY_MS=200

AUTH_INTERNAL_URL=http://localhost:8081
BIDDING_INTERNAL_URL=http://localhost:8082
INTERNAL_API_KEY=local-internal-api-key

# ---- Certificate storage ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=kel4minio
MINIO_SECRET_KEY=kel4miniosecret
MINIO_BUCKET=documents
MINIO_PUBLIC_URL=http://localhost:9000
CERTIFICATE_ISSUER_NAME=Kelompok 4 Tracker Service
WEASYPRINT_BIN=weasyprint

# ---- Pinata / IPFS metadata ----
PINATA_JWT=pinata-jwt-here

# ---- Base Sepolia NFT minting ----
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_NFT_CONTRACT_ADDRESS=0xYourContractAddress
BASE_SEPOLIA_NFT_MINT_FUNCTION=safeMint
BASE_SEPOLIA_NFT_CONTRACT_ABI_JSON=["function safeMint(address to, string uri)","event Transfer(address indexed from, address indexed to, uint256 indexed tokenId)"]
BASE_SEPOLIA_MINTER_PRIVATE_KEY=0xyourprivatekey
BASE_SEPOLIA_RECIPIENT_WALLET=0xYourTestWallet
