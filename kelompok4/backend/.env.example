# Monitoring & Scoring (Tracker) — svc-audit
# Copy to .env and fill in. Do NOT commit real secrets.

# ---- Database (Prisma / PostgreSQL) ----
DATABASE_URL=postgresql://kel4:kel4@localhost:5432/kel4?schema=public

# ---- Redis (assessment cache-aside) ----
REDIS_URL=redis://localhost:6379

# ---- HTTP ----
PORT=8080

# ---- Supabase (document & submission proof storage) ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

# ---- RabbitMQ (outbox -> event bus, nexus integration) ----
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=tracker.events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_ROUTING_PREFIX=tracker
RABBITMQ_PUBLISH_RETRIES=3
RABBITMQ_PUBLISH_RETRY_DELAY_MS=200

# ---- Identity & SSO internal API (reviewer role lookup) ----
AUTH_INTERNAL_URL=http://localhost:8081
INTERNAL_API_KEY=local-internal-api-key
