# versi node.js yang ringan
FROM node:18-alpine

# direktori backend sebagai rootnya (ketika di run)
WORKDIR /app

# Runtime PDF generation (WeasyPrint) + font dasar untuk sertifikat.
RUN apk add --no-cache \
  python3 \
  py3-pip \
  cairo \
  pango \
  gdk-pixbuf \
  libffi \
  ttf-dejavu \
  weasyprint

# copy file package.json + skalian install
COPY package*.json ./
RUN npm install

# copy skema Prisma lalu generate Prisma Client (butuh sebelum copy kode lain)
COPY prisma ./prisma
RUN npx prisma generate

# copy seluruh code backend
COPY . .

# entrypoint: jalankan migrasi skema otomatis sebelum start app
RUN chmod +x docker-entrypoint.sh

# init port untuk dipake backend (cocok dengan gateway & compose integrasi)
EXPOSE 8080

# migrasi skema DB otomatis -> lalu jalankan server
CMD ["sh", "docker-entrypoint.sh"]
