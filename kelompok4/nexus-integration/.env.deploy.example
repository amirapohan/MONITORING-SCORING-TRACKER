# Copy file ini ke ~/nexus/.env di PC dosen, lalu isi nilainya.
# File ini TIDAK dibawa oleh git push — disiapkan satu kali manual.

# Shared
INTERNAL_API_KEY=ganti-dengan-string-acak-panjang
JWT_SECRET=ganti-dengan-string-acak-panjang

# RabbitMQ
RABBIT_USER=guest
RABBIT_PASS=guest

# DB credentials (boleh dibiarkan default untuk dev)
AUTH_DB_USER=auth
AUTH_DB_PASS=auth
AUTH_DB_NAME=auth

BIDDING_DB_USER=bidding
BIDDING_DB_PASS=bidding
BIDDING_DB_NAME=bidding

MATCH_DB_USER=match
MATCH_DB_PASS=match
MATCH_DB_NAME=match

AUDIT_DB_USER=kel4
AUDIT_DB_PASS=kel4
AUDIT_DB_NAME=kel4

# Notify (kosongkan untuk mode log-only, tanpa kirim email beneran)
GMAIL_USER=
GMAIL_PASS=
