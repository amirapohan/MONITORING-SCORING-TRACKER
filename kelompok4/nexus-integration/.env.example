# Copy to .env  ->  cp .env.example .env   (do NOT commit real values)
# Build-from-source mode: no *_IMAGE vars needed.

# ---- RabbitMQ (shared bus) ----
RABBIT_USER=guest
RABBIT_PASS=guest

# ---- Shared auth contract (must match across services) ----
JWT_SECRET=nexus-shared-jwt-secret
INTERNAL_API_KEY=nexus-internal-api-key

# ---- Per-service DB credentials (defaults are fine for local demo) ----
AUTH_DB_USER=auth
AUTH_DB_PASS=auth
AUTH_DB_NAME=auth

BIDDING_DB_USER=bidding
BIDDING_DB_PASS=bidding
BIDDING_DB_NAME=bidding

MATCH_DB_USER=match
MATCH_DB_PASS=match
MATCH_DB_NAME=match

AUDIT_DB_USER=kel4
AUDIT_DB_PASS=kel4
AUDIT_DB_NAME=kel4


# ---- Notification email (optional; empty = log-only, no real email) ----
GMAIL_USER=
GMAIL_PASS=
