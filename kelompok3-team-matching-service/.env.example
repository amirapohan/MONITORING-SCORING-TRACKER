# ======================================================
# Application
# ======================================================
NODE_ENV=development
PORT=8080

# ======================================================
# Database (Prisma)
# ======================================================
# Option A: full connection string — preferred, used directly by Prisma
DATABASE_URL=postgresql://match:match@db-match:5432/match

# Option B: individual parts — nexus compose passes these;
# docker-entrypoint.sh will construct DATABASE_URL automatically if not set above
DATABASE_HOST=db-match
DATABASE_PORT=5432
DATABASE_USER=match
DATABASE_PASSWORD=match
DATABASE_NAME=match

# ======================================================
# Auth / Identity & SSO (kelompok1)
# ======================================================
MOCK_SSO_URL=http://svc-auth:8080
MOCK_SSO_SECRET=nexus-internal-api-key

# Internal service key — must match INTERNAL_API_KEY in nexus .env
INTERNAL_SERVICE_KEY=nexus-internal-api-key

# ======================================================
# RabbitMQ
# ======================================================
RABBITMQ_URL=amqp://guest:guest@rabbit-main:5672
RABBITMQ_EXCHANGE=tracker.events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_ROUTING_PREFIX=tracker
